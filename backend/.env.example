ANTHROPIC_API_KEY=

# SQLite file location (advisor accounts, sessions, workspace data).
# Optional -- defaults to ./data/alphatense.db for local dev. In production
# this points at a Railway persistent volume mount, e.g. /data/alphatense.db.
DATABASE_PATH=

# Xero OAuth2 app credentials (developer.xero.com -> My Apps).
XERO_CLIENT_ID=
XERO_CLIENT_SECRET=
# Optional -- defaults to http://localhost:8000/xero/callback. Must exactly
# match a redirect URI registered on the Xero app.
XERO_REDIRECT_URI=
